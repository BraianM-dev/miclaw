func main() {
	logger.Printf("[INFO] 🚀 Iniciando %s %s", AgentName, AgentVersion)
	appInstance = app.NewWithID("com.afe.assistant")
	mainWindow = appInstance.NewWindow(fmt.Sprintf("%s %s", AgentName, AgentVersion))
	mainWindow.Resize(fyne.NewSize(450, 400))

	loadSettings()
	loadUserProfile()
	loadChatHistory()
	loadActionLog()
	loadPendingEvents()
	loadPlugins()
	loadDynamicRules()
	applyTheme()
	checkForLocalUpdate()
	go retryPendingEvents()

	buildUI()
	startCommandListener()
	go proactiveMonitoring()

	if isFirstRun() {
		showFirstRunWizard()
	} else {
		mainWindow.Hide()
	}

	sendNotification(AgentName, fmt.Sprintf("%s listo.", AgentName))
	appInstance.Run()
	gracefulExit()
}