		ExpectedResponses: []string{"si", "sí"},
		OnConfirm: func(resp string) string {
			exec.Command("msiexec", "/i", installer).Start()
			return "✅ Instalador iniciado."
		},
	}
	return mem.PendingConfirmation.Description
}

